# Compilateur et options
CC = gcc
CFLAGS = -Wall -Wextra -g

# Fichiers source et objet
SRCS = main.c card.c player.c game.c display.c file.c
OBJS = $(SRCS:.c=.o)

# Nom de l'exécutable
TARGET = fliptech

# Règle principale
all: $(TARGET)

# Compilation de l'exécutable
$(TARGET): $(OBJS)
    $(CC) $(CFLAGS) -o $(TARGET) $(OBJS)

# Compilation des fichiers objets
%.o: %.c
    $(CC) $(CFLAGS) -c $< -o $@

# Nettoyage des fichiers compilés (Linux)
clean:
    rm -f *.o $(TARGET)

# Recompilation complète
re: clean all
